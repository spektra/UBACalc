# file: .gitignore

# Build output (never commit this)
dist/
dist-ssr/
build/

# Dependencies
node_modules/
.pnp
.pnp.js

# Vite
*.local
.vite/

# Environment variables
.env
.env.local
.env.*.local
.env.development
.env.production

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / IDE
.vscode/
.idea/
*.suo
*.sw?
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo

# Testing
coverage/

# Misc
.cache/
.temp/
cloudflare-handoff.md
# test artifacts
test-results/
playwright-report/

# debug files
e2e/debug*.spec.ts
e2e/slider-debug*.spec.ts
